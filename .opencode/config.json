{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "small_model": "anthropic/claude-haiku-4-5",
  
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    }
  },
  
  "agent": {
    "plan": {
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0.1,
      "tools": {
        "mcp*": true
      }
    },
    "build": {
      "model": "anthropic/claude-sonnet-4-5",
      "temperature": 0.2
    }
  },
  
  "tools": {
    "write": true,
    "bash": true,
    "edit": true
  },
  
  "permission": {
    "bash": {
      "*": true,
      "rm -rf /": "deny",
      "rm -rf ~": "deny"
    },
    "edit": true,
    "write": true
  },
  
  "instructions": [
    "AGENTS.md",
    ".opencode/skills/browser-use.md",
    ".opencode/skills/agent-browser.md",
    ".opencode/skills/code-review.md",
    ".opencode/skills/test-generator.md",
    ".opencode/skills/git-master.md"
  ],
  
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".venv/**",
      "venv/**",
      "__pycache__/**",
      "*.pyc",
      ".git/**",
      ".pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**"
    ]
  }
}
